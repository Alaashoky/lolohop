# HOPEFX AI Trading — Environment Variables
# Copy to .env and fill in values before starting.
#   cp .env.example .env

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECURITY_JWT_SECRET=CHANGE_ME_generate_a_random_48_char_secret
CONFIG_ENCRYPTION_KEY=CHANGE_ME_generate_a_random_48_char_key

# ── DATABASE ──────────────────────────────────────────────────────────────────
# SQLite (dev): sqlite:///hopefx.db
# Postgres (prod): postgresql://user:password@localhost:5432/hopefx
DATABASE_URL=sqlite:///hopefx.db

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ── APPLICATION ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_BASE_URL=http://localhost:8000
API_HOST=127.0.0.1
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── AUTH ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# ── TRADING ───────────────────────────────────────────────────────────────────
BROKER_TYPE=paper
INITIAL_BALANCE=100000
COMMISSION=3.5
PAPER_USER_ID=paper
SIGNAL_ENGINE_AUTO_TRADE=false

# ── RISK MANAGEMENT ───────────────────────────────────────────────────────────
RISK_MAX_POSITION_SIZE_PCT=0.02
RISK_MAX_DRAWDOWN_PCT=0.10
RISK_MAX_DAILY_LOSS_PCT=0.05

# ── AML GATE ──────────────────────────────────────────────────────────────────
AML_SINGLE_WITHDRAWAL_CAP=10000
AML_DAILY_WITHDRAWAL_LIMIT=50000
AML_MAX_WITHDRAWALS_PER_DAY=5
AML_KYC_THRESHOLD=1000
AML_RAPID_TURNAROUND_HOURS=1

# ── POSITION RECONCILER ───────────────────────────────────────────────────────
RECONCILER_INTERVAL_SECONDS=30

# ── ML TRAINING ───────────────────────────────────────────────────────────────
ML_SYMBOLS=GC=F,EURUSD=X
ML_PERIOD=2y
ML_MODEL_DIR=ml/saved_models

# ── EMAIL (SMTP) ──────────────────────────────────────────────────────────────
# Leave blank to use dev-mode logging (no emails sent)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
FROM_EMAIL=noreply@hopefx.io

# ── PAYMENTS ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── LIVE BROKER CREDENTIALS ───────────────────────────────────────────────────
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────
FEATURE_ML_PREDICTIONS=false
FEATURE_SOCIAL_TRADING=true
FEATURE_COPY_TRADING=true
FEATURE_PAPER_TRADING=true
FEATURE_LIVE_TRADING=false
FEATURE_BACKTESTING=true
FEATURE_MARKET_SCANNER=true
FEATURE_ORDER_FLOW=true
FEATURE_NEWS_SENTIMENT=true
FEATURE_EXPLAINABILITY=false
FEATURE_TRANSPARENCY=false
FEATURE_TEAMS=false
FEATURE_NOCODE_BUILDER=false
FEATURE_REPLAY_ENGINE=false
