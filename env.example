# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hopefx
DB_USER=hopefx
DB_PASSWORD=your_secure_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security (generate with: openssl rand -hex 32)
SECURITY_ENCRYPTION_KEY=your_64_char_hex_key_here
SECURITY_SALT=your_32_char_hex_salt_here
SECURITY_JWT_SECRET=your_jwt_secret_here_32_chars_min

# Brokers
BROKER_DEFAULT=paper
BROKER_OANDA_TOKEN=
BROKER_OANDA_ACCOUNT=
BROKER_OANDA_ENVIRONMENT=practice

# Risk
RISK_MAX_DAILY_LOSS_PCT=2.0
RISK_MAX_POSITION_SIZE_PCT=5.0
RISK_MAX_DRAWDOWN_PCT=10.0
RISK_KILL_SWITCH_ENABLED=true

# ML
ML_MODEL_PATH=./models
ML_RETRAIN_INTERVAL_HOURS=24

# Stripe (required for marketplace)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
